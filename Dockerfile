# 1. Берем за основу готовый образ с Java 21 (это как Windows/Linux + Java)
FROM eclipse-temurin:21-jdk-alpine

# 2. Создаем папку внутри контейнера, где будет лежать приложение
WORKDIR /app

# 3. Копируем наш собранный jar-файл внутрь контейнера
# ВНИМАНИЕ: Имя файла может отличаться! (см. шаг 2)
COPY build/libs/demo-0.0.1-SNAPSHOT.jar app.jar

# 4. Говорим Докеру, какую команду запустить, когда контейнер стартует
ENTRYPOINT ["java", "-jar", "app.jar"]